{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C: clang build active file",
            "type": "cppbuild",
            "command": "D:\\msys64\\clang64\\bin\\clang.exe",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        }
    ]
}
