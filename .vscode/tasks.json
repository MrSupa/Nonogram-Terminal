{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Make Build",
            "type": "shell",
            "command": "mingw32-make",
            "args": ["all"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "D:\\msys64\\clang64\\bin;C:\\msys64\\usr\\bin;${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
