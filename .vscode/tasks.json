{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Make Build",
            "type": "shell",
            "command": "D:\\msys64\\usr\\bin\\bash.exe",
            "args": [
                "--login",
                "-c",
                "cd \"${workspaceFolder}\" && mingw32-make all"
            ],
            "options": {
                "env": {
                    "MSYSTEM": "CLANG64",
                    "PATH": "/clang64/bin:/usr/bin:${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
